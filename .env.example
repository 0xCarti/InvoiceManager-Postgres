# Example environment variables for Invoice Manager
# Copy this file to .env and edit the values for your deployment

SECRET_KEY=changeme
ADMIN_EMAIL=admin@example.com
ADMIN_PASS=adminpass
PORT=5000
DATABASE_DRIVER=postgresql+psycopg
# Docker Compose inter-service DNS uses the service name (`postgres`), not `container_name`.
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=invoicemanager
DATABASE_PASSWORD=invoicemanager
DATABASE_NAME=invoicemanager
DATABASE_URL=postgresql+psycopg://invoicemanager:invoicemanager@postgres:5432/invoicemanager
SQLALCHEMY_POOL_PRE_PING=true
SQLALCHEMY_POOL_RECYCLE=1800
SQLALCHEMY_POOL_TIMEOUT=30
SQLALCHEMY_POOL_SIZE=5
SQLALCHEMY_MAX_OVERFLOW=10
SQLALCHEMY_POOL_USE_LIFO=true
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SENDER=no-reply@example.com
SMTP_USE_TLS=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Storage backend for rate limiting; use Redis in production
RATELIMIT_STORAGE_URI=memory://
